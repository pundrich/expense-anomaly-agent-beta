# Copy this file to .env for local testing of the deploy build.
# In production (Render) these are set in the dashboard under
# Settings → Environment, NOT in a committed file.

# Required - get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Required - Postgres connection string from Neon, Supabase, etc.
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/expense_audit?sslmode=require

# Optional - bundled admin credentials (only used on first run, when the
# users table is empty). After first login, change the password in the app.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin

# Optional - bind config (Render sets PORT for you in production)
HOST=0.0.0.0
PORT=8765
